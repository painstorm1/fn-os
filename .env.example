FN_OS_PASSWORD=change-this-password
FN_OS_AUTH_TOKEN=change-this-long-random-token
FN_OS_API_KEY=change-this-api-key-for-vba

# Supabase REST connection for FN OS native modules
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: temporary import-management API while that menu is migrated into FN OS DB
NEXT_PUBLIC_IMPORT_API_URL=https://your-import-api.example.com

# Naver OAuth / API integration
# Production callback URL registered in Naver Developer Center:
# https://fn-os.vercel.app/api/auth/naver/callback
# Optional local development callback URL:
# http://127.0.0.1:3000/api/auth/naver/callback
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
# Optional: set to 1 only when testing the local callback route.
NAVER_USE_LOCAL_CALLBACK=

# Optional: Archive screenshot/image AI organizer. Falls back to tesseract OCR when omitted.
OPENAI_API_KEY=
ARCHIVE_AI_MODEL=gpt-4.1-mini
