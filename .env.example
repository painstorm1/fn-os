FN_OS_PASSWORD=your-fnos-password
FN_OS_AUTH_TOKEN=your-long-random-session-token
FN_OS_API_KEY=your-fnos-api-key
AUTOMATION_AGENT_TOKEN=your-long-random-automation-agent-token

# Optional additional local product-image roots (Windows path separator: ;)
FNOS_ALLOWED_PRODUCT_IMAGE_ROOTS=

# Supabase REST connection for FN OS native modules
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: temporary import-management API while that menu is migrated into FN OS DB
NEXT_PUBLIC_IMPORT_API_URL=https://your-import-api.example.com

# Optional: FNOS direct email send (Nate SMTP defaults shown)
FNOS_SMTP_HOST=smtp.mail.nate.com
FNOS_SMTP_PORT=465
FNOS_SMTP_USER=
FNOS_SMTP_PASS=
FNOS_SMTP_FROM=sender@example.com
FNOS_SMTP_FROM_NAME=에프엔
FNOS_SMTP_REPLY_TO=reply-to@example.com

# Optional: Archive screenshot/image AI organizer. Falls back to tesseract OCR when omitted.
OPENAI_API_KEY=
ARCHIVE_AI_MODEL=gpt-4.1-mini
